# ==========================================================================
# Variables de entorno para PRODUCCIÓN (Railway / self-host)
# Copia estas claves en el panel de Railway → tu servicio → Variables.
# NO subas este archivo con valores reales al repo.
# ==========================================================================

# --- Servidor ---
HOST=0.0.0.0
PORT=1337
NODE_ENV=production
# URL pública del CMS (la que te da Railway, p.ej. https://perfumes-cms-production.up.railway.app)
PUBLIC_URL=
# Railway/Render van detrás de proxy:
IS_PROXIED=true

# --- Secretos (GENERA NUEVOS para producción) ---
# Genera cada uno con:  node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
# APP_KEYS necesita 4 valores separados por coma.
APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=
JWT_SECRET=

# --- Base de datos: Postgres (Railway lo provee) ---
DATABASE_CLIENT=postgres
# Railway expone la conexión como DATABASE_URL al enlazar el plugin de Postgres:
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
